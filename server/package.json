{
  "name": "desk-server",
  "version": "1.0.0",
  "description": "Desk backend API",
  "main": "src/index.js",
  "scripts": {
    "dev":   "nodemon --watch src src/index.js",
    "start": "node src/index.js",
    "seed":  "node prisma/seed.js",
    "build": "node_modules/.bin/prisma generate && node_modules/.bin/prisma migrate deploy"
  },
  "engines": {
    "node": "18.x"
  },
  "dependencies": {
    "express":        "^4.18.2",
    "@prisma/client": "5.22.0",
    "dotenv":         "^16.3.1",
    "cors":           "^2.8.5",
    "bcryptjs":       "^2.4.3",
    "jsonwebtoken":   "^9.0.2",
    "socket.io":      "^4.7.2",
    "multer":         "^1.4.5-lts.1",
    "cloudinary":     "^1.41.3",
    "@sendgrid/mail": "^8.1.0",
    "zod":            "^3.22.4",
    "cookie-parser":  "^1.4.6",
    "morgan":         "^1.10.0"
  },
  "devDependencies": {
    "prisma":  "5.22.0",
    "nodemon": "^3.0.1"
  }
}
